#!/bin/bash

config='.repoconfig'

Color_Off='\033[0m'       # Text Reset
Red='\033[0;31m'          # Red
Green='\033[0;32m'        # Green

copy_files_from_config () {
  files=$(jq -r '.files | keys[]' < ../$config)

  if [[ ${#files} -eq 0 ]]; then
    echo -e "${Red}No files found in config file${Color_Off}"
  else 
    for file in $files; do
      src=$(jq -r ".files.$file.src" < ../$config)

      src=$(echo "$src" | sed 's/^\.\///')
      src="../$src"

      if [[ ! -e $src ]]; then
        echo -e "${Red}File $src does not exist${Color_Off}"
        continue
      fi

      dest=$(jq -r ".files.$file.dest" < ../$config)

      mkdir -p "$(dirname "$dest")" && cp "$src" "$dest"
      echo -e "${Green}File $src copied to $dest${Color_Off}"
    done
  fi
}

run_scripts_from_config () {
  scripts=$(jq -r '.scripts | keys[]' < ../$config)

  if [[ ${#scripts} -eq 0 ]]; then
    echo -e "${Red}No scripts found in config file${Color_Off}"
  else 
    for script in $scripts; do
      command=$(jq -r ".scripts.$script" < ../$config)
      echo -e "${Green}Running $command${Color_Off}"

      eval "$command"
    done
  fi
}

createConfigFile () {
  if [[ -e $config ]]; then
    reply='n'
    echo -e "${Red}Config file already exists${Color_Off}"

    read -p "Do you want to overwrite it? [y/n] " -n 1 -r
    echo  
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      reply='y'
    fi

    if [[ $reply == 'n' ]]; then
      echo -e "${Red}Aborting${Color_Off}"
      exit 1
    fi

    echo -e "${Green}Creating config file${Color_Off}"
  else 
    echo -e "${Green}Creating config file${Color_Off}" 
  fi

  cat "$HOME"/.config/gwt/.repoconfig.example > $config
}

if [[ $# -eq 0 ]]; then 
  echo "Reading config file"
  ####### FILES
  copy_files_from_config
  ###### SCRIPTS
  run_scripts_from_config
else
  while :; do
    case $1 in
      init)
        createConfigFile
        break
        ;;
      -f)
        copy_files_from_config
        break
        ;;
      -s)
        run_scripts_from_config
        break
        ;;
      *)
        echo "Invalid argument"
        break
    esac
    shift
  done
fi


