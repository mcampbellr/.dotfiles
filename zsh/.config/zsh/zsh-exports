# -------------------------------------------------------------------
# zsh-exports
# Environment variables, XDG, PATH and SDK/toolchain locations
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# 1) Homebrew environment
# -------------------------------------------------------------------
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Make sure zsh can find brew-provided completions (must be before compinit in zshrc)
fpath+=("$(brew --prefix)/share/zsh/site-functions")


# -------------------------------------------------------------------
# 2) Global flags
# -------------------------------------------------------------------
export DOCKER_BUILDKIT=1


# -------------------------------------------------------------------
# 3) History / behavior (you had these here; keeping to avoid behavior changes)
# -------------------------------------------------------------------
unsetopt BEEP
setopt appendhistory
setopt HIST_SAVE_NO_DUPS
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FIND_NO_DUPS


# -------------------------------------------------------------------
# 4) XDG
# -------------------------------------------------------------------
export XDG_RUNTIME_DIR="$HOME/.config"
export XDG_CONFIG_HOME="$HOME/.config"
export DOCKER_CONFIG="$XDG_RUNTIME_DIR/docker"


# -------------------------------------------------------------------
# 5) Environment variables set everywhere
# -------------------------------------------------------------------
export HISTSIZE=10000
export SAVEHIST=$HISTSIZE
export EDITOR="nvim"
export TERMINAL="iterm2"
export BROWSER="brave"
export TERM="xterm-256color"
export HISTFILE=~/.config/zsh/.zsh_history
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=008'
export APPLE_SSH_ADD_BEHAVIOR=1


# -------------------------------------------------------------------
# 6) AWS
# -------------------------------------------------------------------
export AWS_DEFAULT_REGION="us-east-1"
export AWS_DEFAULT_PROFILE="default"
# unset AWS_SECRET_ACCESS_KEY
# unset AWS_ACCESS_KEY_ID


# -------------------------------------------------------------------
# 7) MANPAGER
# -------------------------------------------------------------------
export MANPAGER="sh -c 'col -bx | bat -l man -p'"


# -------------------------------------------------------------------
# 8) Java / JDK
# -------------------------------------------------------------------
export CPPFLAGS="-I/opt/homebrew/opt/openjdk@11/include"

export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"
export JAVA_HOME="/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"


# -------------------------------------------------------------------
# 9) PATH (grouped)
# -------------------------------------------------------------------
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
export PATH="$PATH:$HOME/.local/bin"
export PATH="/usr/local/opt/make/libexec/gnubin:$PATH"
export PATH="/opt/homebrew/opt/gnu-tar/libexec/gnubin:$PATH"
export PATH="$HOME/Developer/flutter/bin:$PATH"
export PATH="$HOME/.tmuxifier/bin:$PATH"
export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"

# Rust env + cargo bin
. "$HOME/.cargo/env"
export PATH="$HOME/.cargo/bin:$PATH"


# -------------------------------------------------------------------
# 10) Android
# -------------------------------------------------------------------
export ANDROID_AVD_HOME="$XDG_RUNTIME_DIR/android"
export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_SDK_ROOT/emulator"
export PATH="$PATH:$ANDROID_SDK_ROOT/platform-tools"
export PATH="$PATH:$ANDROID_HOME/platform-tools"


# -------------------------------------------------------------------
# 11) Personal paths / configs
# -------------------------------------------------------------------
export DOTFILES="$HOME/.dotfiles/"
export TMUX_CONFIG="$HOME/.config/tmux/tmux.conf"
export NOTES="$HOME/Notes/"
export DEV_FILES="$HOME/Developer"
export LG_CONFIG_FILE="$HOME/.config/lazygit/config.yml"
export GIT_CONFIG_GLOBAL="$HOME/.config/git/.gitconfig"

# fzf defaults (NOT init)
export FZF_DEFAULT_COMMAND='fd --type f'
export FZF_COMPLETION_TRIGGER='--'

export CHROME_EXECUTABLE="/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"

export REACT_NATIVE_PACKAGER_HOSTNAME="$(ipconfig getifaddr en0 2>/dev/null)"

export RUST_BACKTRACE=0


# -------------------------------------------------------------------
# 12) Node (nvm)
# -------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"


# -------------------------------------------------------------------
# 13) Optional SDKs
# -------------------------------------------------------------------
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi
if [ -f /opt/homebrew/opt/asdf/asdf.sh ]; then . /opt/homebrew/opt/asdf/asdf.sh; fi
