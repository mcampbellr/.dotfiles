#!/bin/sh
# vim & nvim aliases
alias n='nvim'
alias n.='nvim'
alias nvc="cd $DOTFILES/nvim/.config/nvim && n ."
alias dot="cd $DOTFILES"
alias vc="vimtheme"
# shortcuts aliases
alias cl='clear'
alias ls='exa'
alias la='ls -laFh'
alias ll='ls -l'
alias tree="ls -T -L 3 --git-ignore"

mkcdir () {
  mkdir -p -- "$1" &&
    cd -P -- "$1"
}

alias notes="cd ~/Notes/"

alias ccd=mkcdir
# configs aliases
alias zshrc="cd $DOTFILES/zsh/"
alias src="source ~/.zshrc && echo '< zsh config reloaded >'"

# tmux aliases
alias tm='tmux'
alias :q='exit'
# browser aliases
alias gg='google'
alias sof='stackoverflow'
alias yt='youtube'
# npm version aliases
alias patch="yarn version --patch"
alias minor="yarn version --minor"
alias major="yarn version --major"
# programing language aliases
# python
alias py='python3'
alias pip='pip3' 
# typescript
alias tsn="ts-node"
# react
alias cra='npx create-react-app'
alias crna='npx create-next-app@latest'
alias crnats='npx create-next-app@latest --ts'
# Custom git aliases
alias lg='lazygit'
alias g='git'
alias gwt="g worktree"
alias gwta="g worktree add"
alias gwtr="g worktree remove"
alias gwtm="g worktree move"
alias gwtp="g worktree prune"
alias gcp="g cherry-pick"
alias gri="g rebase -i"
alias gst="g st"
alias gconf="g config --global -e"
alias glg="g log -20 --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'"
alias glog="g log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'"

# Custom commands
alias gsw="$DEV_FILES/git-switcher/git-switcher.sh"
alias cg=". $DEV_FILES/rotator/rot.sh"
alias ch="$DEV_FILES/cht/cht.sh"
alias ss="$DEV_FILES/tmux/session"

alias doc='docker'
alias dco="docker compose"

alias t="todo.sh"

alias cpwd="pwd | tr -d '\n' | pbcopy && echo 'pwd copied to clipboard'"
