[user]
	name = Mario Campbell R
	email = mariocampbellr@gmail.com
[init]
	defaultBranch = main
	templatedir = /Users/mcampbellr/.git-templates
[credential]
	helper = cache
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[alias]
	co = checkout
	cp = cherry-pick
	st = status --short
	or = open-repo
	sw = switch
	wt = worktree
	cm = commit
	rb = rebase
  sv = save
  rs = reset
[push]
	default = current
[pull]
	default = current
[core]
	editor = nvim
	pager = cat
	autocrlf = input
  ignorecase = false
	excludesFile = ~/.gitglobalexclude
[checkout]
  defaultRemote = origin
[worktree]
  guessRemote = true
[help]
	autocorrect = 1
