#!/usr/bin/env bash
config='.repoconfig'

Color_Off='\033[0m'       # Text Reset
Red='\033[0;31m'          # Red
Green='\033[0;32m'        # Green


function processConfigFile {
  echo "Reading config file"
  ####### FILES
  copy_files
  ###### SCRIPTS
  run_scripts
}

copy_files () {
  if [[ ! -e $config ]]; then
    if [[ -e ../$config ]]; then
      config="../$config"
    else 
      echo -e "${Red}-- Config file does not exist --${Color_Off}"
      exit 0
    fi
  fi

  json=`cat $config`

  json_files=`echo $json | jq -r .files`
  file_keys=(`echo $json_files | jq -r keys[]`)
  for ((i = 0; i < ${#file_keys[@]}; i++)); do
    row=${file_keys[$i]}

    file=`echo $json_files | jq -r '.'$row' | .src'`
    dest=`echo $json_files | jq -r '.'$row' | .dest'`
    path=${dest%/}/

    if [[ ! -e $file || ! -s $file ]]; then
      echo "file '$file' not exist"
    elif [[ ! -d $path ]]; then
      echo "$path destination not exist"
    else 
      cp $file $path && echo -e "${Green}success:${Color_Off} $file"
    fi 
  done
}

run_scripts () {
  if [[ ! -e $config ]]; then
    if [[ -e ../$config ]]; then
      config="../$config"
    else 
      echo -e "${Red}-- Config file does not exist --${Color_Off}"
      exit 0
    fi
  fi

  json=`cat $config`
  json_scripts=`echo $json | jq .scripts`
  scripts_keys=(`echo $json_scripts | jq -r keys[]`)
  for ((i = 0; i < ${#scripts_keys[@]}; i++)); do
    row=${scripts_keys[$i]}
    cmd=`echo $json_scripts | jq -r '.'$row`

    $cmd && echo -e "${Green}success running:${Color_Off} $cmd" || echo "error executing script ${cmd}"
  done
}

createConfigFile () {
  if [[ -e $config ]]; then
    echo "Config file already exist"
  else 
    echo "creating new .repoconfig file"
    echo '/*
Example Config
{
  "files": {
    "env": {
      "src": ".env",
      "dest": "/path/to/file"
    }
  },
  "scripts": {
    "packages": "npm install"
  }
}
*/
{}' > $config
  fi
}

if [[ $# -eq 0 ]]; then 
  processConfigFile
else
  while :; do
    case $1 in
      init)
        createConfigFile
        break
        ;;
      -f)
        copy_files
        break
        ;;
      -s)
        run_scripts
        break
        ;;
      -?* | --?*)
        echo "Invalid argument"
        break
        ;;
      *)
        break
    esac
    shift
  done
fi


