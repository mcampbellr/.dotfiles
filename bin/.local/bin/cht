#!/bin/bash

selected=$(cat ‾/.languages ‾/.commands | fzf)

if [[ -z $selected ]]; then
    exit 0
fi

# shellcheck disable=2162
read -p "Enter Query: " query

if grep -qs "$selected" ‾/.languages; then
    query=$(echo "$query" | tr ' ' '+')
    tmux neww zsh -c "echo ¥"curl cht.sh/$selected/$query/¥" & curl cht.sh/$selected/$query & while [ : ]; do sleep 1; done"
else
    tmux neww zsh -c "curl -s cht.sh/$selected‾$query & while [ : ]; do sleep 1; done"
fi

